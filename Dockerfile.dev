FROM node:20-alpine

# ── npm mirror ────────────────────────────────────────────────────────────────
RUN npm config set registry https://npm.devneeds.ir

WORKDIR /app

# Install dependencies — source is bind-mounted at runtime, not copied here
COPY package.json package-lock.json ./
RUN npm ci

EXPOSE 3000
CMD ["npm", "run", "dev"]
